# Copie para .env (nunca commite o .env real!)

# JWT — gere uma chave segura: openssl rand -base64 64
JWT_SECRET=troque-por-uma-chave-segura-de-no-minimo-32-caracteres
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# Banco (produção Azure PostgreSQL)
DB_HOST=seaport-db.postgres.database.azure.com
DB_PORT=5432
DB_NAME=seaportdb
DB_USERNAME=seaport_admin
DB_PASSWORD=senha-segura-aqui

# Email (produção)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG.sua-chave-sendgrid


# URLs
FRONTEND_URL=https://seaport.azurewebsites.net
CORS_ALLOWED_ORIGINS=https://seaport.azurewebsites.net

# Profile
SPRING_PROFILES_ACTIVE=prod

# Token de recuperação (minutos)
PASSWORD_RESET_EXPIRATION=30
