# ============================================================
# SEAPORT BACKEND — Variáveis de Ambiente
# ------------------------------------------------------------
# 1. Copie este arquivo:  cp .env.example .env   (Linux/Mac)
#                         copy .env.example .env  (Windows)
# 2. Ajuste os valores conforme seu ambiente
# 3. NUNCA commite o arquivo .env
# ============================================================

# ── Perfil ──────────────────────────────────────────────────
# "dev"  → usa H2 em arquivo local (sem banco externo necessário)
# "prod" → usa PostgreSQL (configure DB_* abaixo)
SPRING_PROFILES_ACTIVE=dev

# ── JWT ─────────────────────────────────────────────────────
# Gere uma chave segura: openssl rand -base64 48
JWT_SECRET=seaport-dev-secret-key-change-in-production-min-32-chars
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Admin inicial (criado automaticamente se banco vazio) ────
APP_ADMIN_PASSWORD=Seaport@2024

# ── Banco de dados (apenas perfil prod / Docker) ─────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seaportdb
DB_USERNAME=seaport
DB_PASSWORD=seaport123

# ── Email ────────────────────────────────────────────────────
# Dev: docker compose up -d mailhog  → acesse http://localhost:8025
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# Produção (SendGrid):
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.sua-chave-sendgrid

# ── CORS / Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ── Upload de arquivos ───────────────────────────────────────
APP_STORAGE_LOCATION=./uploads

# ── Reset de senha (minutos) ─────────────────────────────────
PASSWORD_RESET_EXPIRATION=30

# ── Produção Azure (preencher no App Service, não aqui) ──────
# DB_HOST=seaport-db.postgres.database.azure.com
# DB_USERNAME=seaport_admin
# DB_PASSWORD=senha-segura-aqui
# FRONTEND_URL=https://seaport.azurewebsites.net
# CORS_ALLOWED_ORIGINS=https://seaport.azurewebsites.net
# SPRING_PROFILES_ACTIVE=prod
